{
  "name": "app-store-server-api",
  "version": "1.0.0",
  "description": "A client for the App Store Server API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "package": "npm run build && npm pack"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "app",
    "store",
    "server",
    "api",
    "apple",
    "in-app",
    "purchase",
    "iap",
    "subscription",
    "receipt",
    "validation",
    "notifications"
  ],
  "license": "MIT",
  "homepage": "https://github.com/agisboye/app-store-server-api",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/agisboye/app-store-server-api.git"
  },
  "bugs": {
    "url": "https://github.com/agisboye/app-store-server-api/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "prettier": {
    "semi": false,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "none",
    "arrowParens": "avoid",
    "printWidth": 160
  }
}
