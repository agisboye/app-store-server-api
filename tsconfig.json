{
  "compilerOptions": {
    /* Recommended base for Node.js 22 (@tsconfig/node22) */
    "lib": ["es2024", "ESNext.Array", "ESNext.Collection", "ESNext.Iterator"],
    "module": "nodenext",
    "moduleResolution": "node16",
    "target": "es2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    /* Single native-ESM build emitting JS + type declarations */
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}
